.navbarBrand {
  padding-top: 0.3125rem;
  padding-bottom: 0.3125rem;
  margin-right: 1rem;
  font-size: 1.25rem;
  text-decoration: none;
  white-space: nowrap;
  color: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
}

.navbarBrand:hover,
.navbarBrand:focus {
  color: rgba(0, 0, 0, 0.9);
}

.navbarToggler {
  cursor: pointer;
  padding: 0.5rem 0.75rem;
  border: 1px solid black;
  border-radius: 0.25rem;
}

.navbarToggler span {
  display: block;
  width: 24px;
  height: 2px;
  border-radius: 1000px;
  background-color: black;
}

.navbarToggler > span:not(:last-child) {
  margin-bottom: 5px;
}

.navbarToggler,
.navbarToggler > span {
  transition: all 0.4s ease-in-out;
}

.navbarToggler.active {
  transition-delay: 0.8s;
  transform: rotate(45deg);
}

.navbarToggler.active > span:nth-child(2) {
  width: 0;
}

.navbarToggler.active > span:nth-child(1),
.navbarToggler.active > span:nth-child(3) {
  transition-delay: 0.4s;
}

.navbarToggler.active > span:nth-child(1) {
  transform: translateY(9px);
}

.navbarToggler.active > span:nth-child(1) {
  transform: translateY(-9px) rotate(90deg);
}

/*
** Hero Section Styles.
*/
.heroSection {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background-color: rgb(248, 243, 238);
}

.heroImage {
  display: block;
  width: 250px;
  width: 250px;
}

@media (min-width: 992px) {
  .heroImage {
    width: 450px;
    height: 400px;
    position: absolute;
    top: -18rem;
    left: 2rem;
  }
}

.heroSection h1 {
  font-size: calc(1.5vw + 2.5rem);
  font-family: "Gill Sans", "Gill Sans MT", Calibri, "Trebuchet MS", sans-serif;
}

@media (min-width: 512px) {
  .heroSection h1 {
    font-size: calc(1.5vw + 3.5rem);
  }
}

/*
** Services Styles.
*/

.services > *:not(:last-child),
.services > *:not(:first-child) {
  margin-top: 1rem;
  margin-bottom: 1rem;
}

.service {
  justify-content: space-between;
  border: 1px solid rgb(187, 187, 187);
  border-radius: 0.25rem;
  padding: 0.5rem;
}

@media (min-width: 992px) {
  .service {
    justify-content: space-between;
    padding: 5.5rem 1.25rem;
    margin-top: 3rem;
    margin-bottom: 3rem;
    border: none;
  }
}

/*
** Work Process Styles.
*/

.workProcess {
  min-height: 100vh;
  color: rgb(251, 248, 248);
  padding: 3rem 1.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

@media (min-width: 992px) {
  .workProcess {
    padding: 3rem;
  }
}

.workProcess .bigHeading {
  font-size: 3rem;
  font-weight: 600;
  margin-top: 3rem;
  margin-bottom: 3rem;
}

@media (min-width: 512px) {
  .workProcess .bigHeading {
    font-size: calc(1.5vw + 2.5rem);
  }
}

.workProcess .processes {
  display: flex;
  flex-direction: column;
}

@media (min-width: 992px) {
  .workProcess .processes {
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    padding: 2rem 0.5rem;
    overflow-x: auto;
  }
}
/*
** Call To Action Styles.
*/

.callToAction {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 90vh;
  padding: 2.5rem 3rem;
}

.callToAction .bigHeading {
  margin-top: 0.7rem;
  margin-bottom: 0.5rem;
  font-size: 3rem;
  line-height: 0.8;
  font-weight: 800;
  text-transform: uppercase;
}

@media (min-width: 576px) {
  .callToAction .bigHeading {
    font-size: 4rem;
  }
}

.callToAction .buttonGroup {
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.callToAction .buttonGroup > * {
  width: 100%;
  max-width: 100%;
  margin-top: 0.5rem;
}

@media (min-width: 576px) {
  .callToAction .buttonGroup {
    flex-direction: row;
  }

  .callToAction .buttonGroup > * {
    width: auto;
    margin-top: 0.5rem;
  }
}

.callToAction .footer {
  position: absolute;
  width: 100%;
  right: 0;
  left: 0;
  bottom: 0;
  top: auto;
}

.callToAction .footerText {
  font-size: 0.8rem;
  line-height: 1rem;
  color: rgb(130, 128, 128);
  margin-bottom: 1rem;
  text-transform: uppercase;
  text-align: center;
}
