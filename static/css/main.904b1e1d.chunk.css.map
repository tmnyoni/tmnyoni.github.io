.navbarBrand {
  padding-top: 0.3125rem;
  padding-bottom: 0.3125rem;
  margin-right: 1rem;
  font-size: 1.1rem;
  font-weight: 500;
  text-decoration: none;
  white-space: nowrap;
  color: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
}

.navbarBrand:hover,
.navbarBrand:focus {
  color: rgba(0, 0, 0, 0.9);
}

.navbarToggler {
  cursor: pointer;
  padding: 0.5rem 0.75rem;
  border: 1px solid black;
  border-radius: 0.25rem;
}

.navbarToggler span {
  display: block;
  width: 24px;
  height: 2px;
  border-radius: 1000px;
  background-color: black;
}

.navbarToggler > span:not(:last-child) {
  margin-bottom: 5px;
}

.navbarToggler,
.navbarToggler > span {
  transition: all 0.4s ease-in-out;
}

.navbarToggler.active {
  background-color: yellow;
}

.navbarToggler.active > span {
  transition-delay: 0.8s;
  transform: rotate(45deg);
}

.navbarToggler.active > span:nth-child(2) {
  width: 0;
}

.navbarToggler.active > span:nth-child(1),
.navbarToggler.active > span:nth-child(3) {
  transition-delay: 0.4s;
}

.navbarToggler.active > span:nth-child(1) {
  transform: translateY(9px);
}

.navbarToggler.active > span:nth-child(1) {
  transform: translateY(-9px) rotate(90deg);
}

.navbarCollapse {
  flex-basis: 100%;
  flex-grow: 1;
  align-items: center;
  height: 100vh;
}

@media (min-width: 992px) {
  .navbarCollapse {
    display: flex !important;
    flex-basis: auto;
    height: auto;
  }
}
/*
** Hero Section Styles.
*/
.heroSection {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background-color: rgb(248, 243, 238);
}

.heroImage {
  display: block;
  width: 250px;
  width: 250px;
  transition: left 0.2s ease-in-out, top 0.15s ease-in;
}

@media (min-width: 992px) {
  .heroImage {
    width: 450px;
    height: 450px;
    position: absolute;
    top: -18rem;
    left: 2rem;
  }
}

.heroSection .salutation {
  color: #9ca3a5;
  font-size: 1.1rem;
}

.heroSection h1 {
  font-size: calc(1.5vw + 2.5rem);
  font-family: "Gill Sans", "Gill Sans MT", Calibri, "Trebuchet MS", sans-serif;
  opacity: 0;
  animation: revealAnimation 0.8s forwards;
}

@media (min-width: 512px) {
  .heroSection h1 {
    font-size: calc(1.5vw + 3.5rem);
  }
}

.heroSection .lead {
  font-size: 1.25rem;
  font-weight: 500;
  margin-top: 2.8rem;
  margin-bottom: 4.8rem;
  animation: revealAnimation 1.2s forwards;
}

@keyframes revealAnimation {
  from {
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: none;
  }
}

.heroSection .ctaBtn {
  position: relative;
  text-decoration: none;
  letter-spacing: 2px;
  color: rgb(241, 241, 241);
  font-weight: 500;
  background-color: #1a1e21;
  outline: 2px solid #1a1e21;
  padding: 0.8rem 2rem;
  border-radius: 0.25rem;
  overflow: hidden;
  transition: color 1s;
}

.heroSection .ctaBtn:hover {
  color: #fff;
  border-color: #1a1e21e1;
}

.heroSection .ctaBtn:focus {
  border-color: #1a1e21;
  box-shadow: 0 0 0 0.25rem rgba(66, 70, 73, 0.5);
}

.heroSection .ctaBtn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -15px;
  width: 0;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.757);
  transform: skew(35deg);
  transition: width 1s;
}

.heroSection .ctaBtn:hover::before {
  width: 150%;
}

/*
** Services Styles.
*/

.services > *:not(:last-child),
.services > *:not(:first-child) {
  margin-top: 1rem;
  margin-bottom: 1rem;
}

.service {
  justify-content: space-between;
  border: 1px solid rgb(187, 187, 187);
  border-radius: 0.25rem;
  padding: 0.5rem;
  font-size: 1.1rem;
}

@media (min-width: 992px) {
  .service {
    justify-content: space-between;
    padding: 5.5rem 1.25rem;
    margin-top: 3rem;
    margin-bottom: 3rem;
    border: none;
  }
}

.servicesCta {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1a1e21;
  color: white;
}

.servicesCta {
  font-size: calc(1.5vw + 2.5rem);
}

@media (min-width: 512px) {
  .servicesCta h1 {
    font-size: calc(1.5vw + 3rem);
  }
}
/*
** Work Process Styles.
*/

.workProcess {
  min-height: 100vh;
  color: rgb(251, 248, 248);
  padding: 3rem 1.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

@media (min-width: 992px) {
  .workProcess {
    padding: 3rem;
  }
}

.workProcess .bigHeading {
  font-size: 3rem;
  font-weight: 600;
  margin-top: 3rem;
  margin-bottom: 3rem;
}

@media (min-width: 512px) {
  .workProcess .bigHeading {
    font-size: calc(1.5vw + 2.5rem);
  }
}

.workProcess .processes {
  display: flex;
  flex-direction: column;
}

.processes::-webkit-scrollbar {
  width: 1px;
}

.processes::-webkit-scrollbar-track {
  box-shadow: inset 0 0 5px rgb(225, 225, 225);
  border-radius: 10px;
  cursor: pointer;
}

.processes::-webkit-scrollbar-thumb {
  background: #314257;
  border-radius: 10px;
  height: 0.5rem;
  cursor: pointer;
}

.processes::-webkit-scrollbar-thumb:hover {
  background: #293d54;
  cursor: pointer;
}

@media (min-width: 992px) {
  .workProcess .processes {
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    padding: 2rem 0.5rem;
    overflow-x: auto;
  }
}
/*
** Call To Action Styles.
*/

.callToAction {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 90vh;
  padding: 2.5rem 3rem;
}

.callToAction .bigHeading {
  margin-top: 0.7rem;
  margin-bottom: 0.5rem;
  font-size: 3rem;
  line-height: 0.8;
  font-weight: 800;
  text-transform: uppercase;
}

@media (min-width: 576px) {
  .callToAction .bigHeading {
    font-size: 4rem;
  }
}

.callToAction .buttonGroup {
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.callToAction .buttonGroup > * {
  width: 100%;
  max-width: 100%;
  margin-top: 0.5rem;
}

@media (min-width: 576px) {
  .callToAction .buttonGroup {
    flex-direction: row;
  }

  .callToAction .buttonGroup > * {
    width: auto;
    margin-top: 0.5rem;
  }
}

.callToAction .footer {
  position: absolute;
  width: 100%;
  right: 0;
  left: 0;
  bottom: 0;
  top: auto;
}

.callToAction .footerText {
  font-size: 0.8rem;
  line-height: 1rem;
  color: rgb(130, 128, 128);
  margin-bottom: 1rem;
  text-transform: uppercase;
  text-align: center;
}

/* animations */

@media (min-width: 992px) {
  .growAnimation {
    transition: transform 5s ease-in-out;
    transform: scale(1.3);
  }
}
